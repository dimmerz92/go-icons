templ Microfrontends(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<path d="M7.5 7.5l4.5 4.5l4.5 -4.5"></path>
		<path d="M6 16v-4"></path>
		<path d="M18 16v-4"></path>
