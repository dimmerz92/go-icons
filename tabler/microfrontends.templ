		<path d="M16 18a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"></path>
		<path d="M4 6a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"></path>
		<path d="M4 18a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"></path>
	</svg>
}
