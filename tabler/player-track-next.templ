package tabler

// tags: [music, forward, play, song, playlist, player, track, next, content, entertainment]
// category: Media
// version: "1.28"
// unicode: "ed4b"
templ PlayerTrackNext(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<path d="M3 5v14l8 -7l-8 -7"></path>
		<path d="M14 5v14l8 -7l-8 -7"></path>
	</svg>
}
