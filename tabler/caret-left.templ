package tabler

// tags: [back, previous, caret, left, navigation, flow, movement, route, path]
// category: Arrows
// version: "1.2"
// unicode: "eb5e"
templ CaretLeft(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<path d="M14 6l-6 6l6 6v-12"></path>
	</svg>
}
