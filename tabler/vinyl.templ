package tabler

// tags: [music, audio, dj, sound, retro, musical, vinyl, hardware, technology, electronic]
// category: Devices
// version: "1.53"
// unicode: "f00d"
templ Vinyl(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<path d="M16 3.937a9 9 0 1 0 5 8.063"></path>
		<path d="M11 12a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"></path>
		<path d="M19 4a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"></path>
		<path d="M20 4l-3.5 10l-2.5 2"></path>
	</svg>
}
