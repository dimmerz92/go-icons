package tabler

// tags: [sign, horoscope, constellation, stars, zodiac, gemini, astrology, star]
// category: Zodiac
// version: "1.17"
// unicode: "ecb0"
templ ZodiacGemini(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<path d="M3 3a21 21 0 0 0 18 0"></path>
		<path d="M3 21a21 21 0 0 1 18 0"></path>
		<path d="M7 4.5l0 15"></path>
		<path d="M17 4.5l0 15"></path>
	</svg>
}
