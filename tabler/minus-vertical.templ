package tabler

// category: System
// tags: [subtract, less, divide, minus, vertical, remove, decrease, negative]
// version: "1.39"
// unicode: "eeb4"
templ MinusVertical(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<path d="M12 5v14"></path>
	</svg>
}
