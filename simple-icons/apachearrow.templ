package simpleicons

templ Apachearrow(attrs ...templ.Attributes) {
	<svg
		role="img"
		viewBox="0 0 24 24"
		xmlns="http://www.w3.org/2000/svg"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<title>Apache Arrow</title><path d="m0 2 10 10L0 22v-4l6-6-6-6zm7 0 10 10L7 22v-4l6-6-6-6zm7 0 10 10-10 10v-4l6-6-6-6z"></path>
	</svg>
}
