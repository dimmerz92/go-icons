package simpleicons

templ Printables(attrs ...templ.Attributes) {
	<svg
		role="img"
		viewBox="0 0 24 24"
		xmlns="http://www.w3.org/2000/svg"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<title>Printables</title><path d="M3.678 4.8 12 9.6v9.6l8.322-4.8V4.8L12 0ZM12 19.2l-8.322-4.8V24Z"></path>
	</svg>
}
