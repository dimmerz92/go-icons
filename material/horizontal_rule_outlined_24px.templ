package material

templ Horizontal_rule_outlined_24px(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		enable-background="new 0 0 24 24"
		height="24"
		viewBox="0 0 24 24"
		width="24"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<g><rect fill="none" fill-rule="evenodd" height="24" width="24"></rect><g><rect fill-rule="evenodd" height="2" width="16" x="4" y="11"></rect></g></g>
	</svg>
}
