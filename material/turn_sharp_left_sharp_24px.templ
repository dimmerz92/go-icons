package material

templ Turn_sharp_left_sharp_24px(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		enable-background="new 0 0 24 24"
		height="24"
		viewBox="0 0 24 24"
		width="24"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<g><rect fill="none" height="24" width="24"></rect></g><g><polygon points="6,6.83 4.41,8.41 3,7 7,3 11,7 9.59,8.41 8,6.83 8,13 18,13 18,21 16,21 16,15 6,15"></polygon></g>
	</svg>
}
