package material

templ Man_2_sharp_24px(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		enable-background="new 0 0 24 24"
		height="24"
		viewBox="0 0 24 24"
		width="24"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<g><rect fill="none" height="24" width="24"></rect></g><g><g><polygon points="16,7 8,7 8,15 10.5,15 10.5,22 13.5,22 13.5,15 16,15"></polygon><circle cx="12" cy="4" r="2"></circle></g></g>
	</svg>
}
