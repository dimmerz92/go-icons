package material

templ Square_two_tone_24px(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		enable-background="new 0 0 24 24"
		height="24"
		viewBox="0 0 24 24"
		width="24"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<g><rect fill="none" height="24" width="24"></rect></g><g><g opacity=".3"><rect height="14" width="14" x="5" y="5"></rect></g><g><path d="M3,3v18h18V3H3z M19,19H5V5h14V19z"></path></g></g>
	</svg>
}
