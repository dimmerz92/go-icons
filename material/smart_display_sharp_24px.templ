package material

templ Smart_display_sharp_24px(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		enable-background="new 0 0 24 24"
		height="24"
		viewBox="0 0 24 24"
		width="24"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<g><rect fill="none" height="24" width="24" y="0"></rect></g><g><path d="M22,4H2v16h20V4z M9.5,16.5v-9l7,4.5L9.5,16.5z"></path></g>
	</svg>
}
