	>
		<g><rect fill="none" height="24" width="24"></rect><rect fill="none" height="24" width="24"></rect><rect fill="none" height="24" width="24"></rect></g><g><path d="M4,18l8.5-6L4,6V18z M13,6v12l8.5-6L13,6z"></path></g>
