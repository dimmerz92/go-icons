package material

templ Folder_off_sharp_24px(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		enable-background="new 0 0 24 24"
		height="24"
		viewBox="0 0 24 24"
		width="24"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<g><rect fill="none" height="24" width="24"></rect></g><g><g><polygon points="12,6 10,4 6.83,4 22,19.17 22,6"></polygon><polygon points="2.1,2.1 0.69,3.51 2,4.83 2,20 17.17,20 20.49,23.31 21.9,21.9"></polygon></g></g>
	</svg>
}
