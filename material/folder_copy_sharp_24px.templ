package material

templ Folder_copy_sharp_24px(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		enable-background="new 0 0 24 24"
		height="24"
		viewBox="0 0 24 24"
		width="24"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<g><rect fill="none" height="24" width="24"></rect></g><g><g><polygon points="3,6 1,6 1,21 20,21 20,19 3,19"></polygon><path d="M23,4h-9l-2-2H5.01L5,17h18V4z"></path></g></g>
	</svg>
}
