package material

templ Data_array_24px(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		enable-background="new 0 0 24 24"
		height="24"
		viewBox="0 0 24 24"
		width="24"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<g><rect fill="none" height="24" width="24"></rect></g><g><g><polygon points="15,4 15,6 18,6 18,18 15,18 15,20 20,20 20,4"></polygon><polygon points="4,20 9,20 9,18 6,18 6,6 9,6 9,4 4,4"></polygon></g></g>
	</svg>
}
