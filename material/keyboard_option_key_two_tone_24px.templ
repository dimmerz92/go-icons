package material

templ Keyboard_option_key_two_tone_24px(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		enable-background="new 0 0 24 24"
		height="24"
		viewBox="0 0 24 24"
		width="24"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<g><rect fill="none" height="24" width="24"></rect></g><g><g><rect height="2" width="6" x="15" y="5"></rect><polygon points="9,5 3,5 3,7 7.85,7 14.77,19 21,19 21,17 15.93,17"></polygon></g></g>
	</svg>
}
