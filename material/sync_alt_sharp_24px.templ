package material

templ Sync_alt_sharp_24px(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		enable-background="new 0 0 24 24"
		height="24"
		viewBox="0 0 24 24"
		width="24"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<g><rect fill="none" height="24" width="24"></rect></g><g><g><polygon points="18,12 22,8 18,4 18,7 3,7 3,9 18,9"></polygon><polygon points="6,12 2,16 6,20 6,17 21,17 21,15 6,15"></polygon></g></g>
	</svg>
}
