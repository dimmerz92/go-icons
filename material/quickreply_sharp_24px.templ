package material

templ Quickreply_sharp_24px(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		enable-background="new 0 0 24 24"
		height="24"
		viewBox="0 0 24 24"
		width="24"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<g><rect fill="none" height="24" width="24"></rect></g><g><g><g><polygon points="22,2 2,2 2,22 6,18 15,18 15,10 22,10"></polygon></g><g><polygon points="22.5,16 20.3,16 22,12 17,12 17,18 19,18 19,23"></polygon></g></g></g>
	</svg>
}
