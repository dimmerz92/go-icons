package radixicons

templ VercelLogo(attrs ...templ.Attributes) {
	<svg
		width="15"
		height="15"
		viewBox="0 0 15 15"
		fill="none"
		xmlns="http://www.w3.org/2000/svg"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<path d="M14.3998 13H0.599976L7.50037 1L14.3998 13ZM2.32849 12H12.6713L7.49939 3.00488L2.32849 12Z" fill="currentColor"></path>
	</svg>
}
