package radixicons

templ TriangleRight(attrs ...templ.Attributes) {
	<svg
		width="15"
		height="15"
		viewBox="0 0 15 15"
		fill="none"
		xmlns="http://www.w3.org/2000/svg"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<path d="M10.5 7.5L6 11L6 4L10.5 7.5Z" fill="currentColor"></path>
	</svg>
}
