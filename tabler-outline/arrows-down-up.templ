package tableroutline

// tags: [direction, north, south, arrows, down, bottom, decrease, top, increase, navigation]
// category: Arrows
// version: "1.35"
// unicode: "edac"
templ ArrowsDownUp(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<path d="M17 3l0 18"></path>
		<path d="M10 18l-3 3l-3 -3"></path>
		<path d="M7 21l0 -18"></path>
		<path d="M20 6l-3 -3l-3 3"></path>
	</svg>
}
