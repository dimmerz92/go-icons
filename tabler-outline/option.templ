package tableroutline

// category: Symbols
// tags: [apple, key, keyboard, option]
// version: "1.0"
// unicode: "1019f"
templ Option(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<path d="M14 6h5m0 12h-5l-5 -12h-4"></path>
	</svg>
}
