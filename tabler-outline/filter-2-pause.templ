package tableroutline

// tags: [filter, pause, sort, organize, arrange, select, refine, sieve, screen, stop]
// category: System
// version: "3.32"
// unicode: "10154"
templ Filter2Pause(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<path d="M4 6h16"></path>
		<path d="M6 12h12"></path>
		<path d="M9 18h4"></path>
		<path d="M17 17v5"></path>
		<path d="M21 17v5"></path>
	</svg>
}
