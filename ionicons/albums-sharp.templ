package ionicons

templ AlbumsSharp(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="512"
		height="512"
		viewBox="0 0 512 512"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<rect x="128" y="64" width="256" height="32"></rect><rect x="96" y="112" width="320" height="32"></rect><path d="M464,448H48V160H464Z"></path>
	</svg>
}
