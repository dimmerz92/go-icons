package ionicons

templ FilterSharp(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="512"
		height="512"
		viewBox="0 0 512 512"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<rect x="16" y="120" width="480" height="48"></rect><rect x="96" y="232" width="320" height="48"></rect><rect x="192" y="344" width="128" height="48"></rect>
	</svg>
}
