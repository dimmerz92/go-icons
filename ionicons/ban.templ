package ionicons

templ Ban(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		viewBox="0 0 512 512"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<circle fill="none" stroke="#000" stroke-miterlimit="10" stroke-width="48" cx="256" cy="256" r="200"></circle><line stroke="#000" stroke-miterlimit="10" stroke-width="48" x1="114.58" y1="114.58" x2="397.42" y2="397.42"></line>
	</svg>
}
