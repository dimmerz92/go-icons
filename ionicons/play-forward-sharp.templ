package ionicons

templ PlayForwardSharp(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="512"
		height="512"
		viewBox="0 0 512 512"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<polygon points="16 400 256 256 16 112 16 400"></polygon><polygon points="256 400 496 256 256 112 256 400"></polygon>
	</svg>
}
