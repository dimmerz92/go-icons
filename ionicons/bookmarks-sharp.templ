package ionicons

templ BookmarksSharp(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="512"
		height="512"
		viewBox="0 0 512 512"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<polygon points="112 0 112 48 416 48 416 416 464 448 464 0 112 0"></polygon><polygon points="48 80 48 512 216 388 384 512 384 80 48 80"></polygon>
	</svg>
}
