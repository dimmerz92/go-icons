package ionicons

templ CellularSharp(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="512"
		height="512"
		viewBox="0 0 512 512"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<path d="M496,432H400V80h96Z"></path><path d="M368,432H272V160h96Z"></path><path d="M240,432H144V224h96Z"></path><path d="M112,432H16V288h96Z"></path>
	</svg>
}
