package ionicons

templ BanOutline(attrs ...templ.Attributes) {
	<svg
		id="icons"
		xmlns="http://www.w3.org/2000/svg"
		viewBox="0 0 512 512"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<circle cx="256" cy="256" r="208" fill="none" stroke="#000" stroke-miterlimit="10" stroke-width="32"></circle><line x1="108.92" y1="108.92" x2="403.08" y2="403.08" fill="none" stroke="#000" stroke-miterlimit="10" stroke-width="32"></line>
	</svg>
}
