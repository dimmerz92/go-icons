package ionicons

templ PodiumSharp(attrs ...templ.Attributes) {
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="512"
		height="512"
		viewBox="0 0 512 512"
		if len(attrs) > 0 {
			{ attrs[0]... }
		}
	>
		<rect x="160" y="32" width="192" height="448"></rect><rect x="384" y="192" width="112" height="288"></rect><rect x="16" y="128" width="112" height="352"></rect>
	</svg>
}
